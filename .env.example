# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://analytics_user:PASSWORD@db.SUPABASE_REF.supabase.co:6543/postgres
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=2

# ── Server ────────────────────────────────────────────
PORT=8080
ENV=development

# ── API Auth ──────────────────────────────────────────
API_KEYS=your-api-key-here

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Spotify (Enhanced Bulk API) ───────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_LICENSOR_ID=

# ── Apple Music ───────────────────────────────────────
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── YouTube ───────────────────────────────────────────
YOUTUBE_SERVICE_ACCOUNT_JSON=
YOUTUBE_CONTENT_OWNER_ID=

# ── Amazon Music ──────────────────────────────────────
AMAZON_API_KEY=
AMAZON_API_SECRET=

# ── GCP ───────────────────────────────────────────────
GCP_PROJECT_ID=matter-collective
PUBSUB_TOPIC=analytics-sync-trigger

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=text
